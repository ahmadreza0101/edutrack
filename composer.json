{
    "name": "hype/uas",
    "autoload": {
        "psr-4": {
            "Hype\\Uas\\": "src/"
        }
    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "tecnickcom/tcpdf": "^6.11"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
